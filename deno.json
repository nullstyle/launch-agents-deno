{
  "name": "@nullstyle/launch-agents",
  "exports": "./mod.ts",
  "tasks": {
    "check": "deno check --doc mod.ts src/*.ts tests/*.ts && deno check --doc-only README.md",
    "coverage": "deno test --allow-read=tests --allow-write=tests --coverage=coverage && deno coverage coverage",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-read=tests --allow-write=tests",
    "test:doc": "deno test --doc --allow-read=$TMPDIR --allow-write=$TMPDIR mod.ts src/"
  },
  "exclude": ["coverage", "tests/.tmp"],
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  }
}
